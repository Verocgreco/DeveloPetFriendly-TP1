doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title TechRetail Solutions
    style.
      body {
        font-family: Arial, sans-serif;
        margin: 40px;
        background: #f4f6f8;
        color: #222;
      }

      h1 {
        color: #0d47a1;
      }

      .card {
        background: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
        max-width: 500px;
      }

      a {
        color: #1565c0;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

  body
    block content